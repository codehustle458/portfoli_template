<script>
  // Cursor dot
  const dot = document.getElementById('cursorDot');
  document.addEventListener('mousemove', e => {
    dot.style.left = e.clientX + 'px';
    dot.style.top = e.clientY + 'px';
  });

  // Scroll reveal
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  reveals.forEach(el => observer.observe(el));

  // Stagger
  document.querySelectorAll('.skills-grid .skill-group').forEach((el, i) => {
    el.style.transitionDelay = (i * 0.08) + 's';
  });
  document.querySelectorAll('.cert-grid .cert-card').forEach((el, i) => {
    el.style.transitionDelay = (i * 0.07) + 's';
  });

  // ── PROJECTS CAROUSEL ──
  const cards = Array.from(document.querySelectorAll('.project-card'));
  const dotsContainer = document.getElementById('carouselDots');
  const currentNum = document.getElementById('currentNum');
  const carouselEl = document.getElementById('projectsCarousel');
  let current = 0;
  let animating = false;

  // Measure tallest card and set carousel height
  function setCarouselHeight() {
    // Temporarily make all cards visible & in-flow to measure
    cards.forEach(c => {
      c.style.opacity = '0';
      c.style.position = 'relative';
      c.style.pointerEvents = 'none';
    });
    let maxH = 0;
    cards.forEach(c => { maxH = Math.max(maxH, c.offsetHeight); });
    // Restore absolute positioning
    cards.forEach(c => {
      c.style.position = '';
      c.style.opacity = '';
    });
    carouselEl.style.height = maxH + 'px';
  }

  setCarouselHeight();
  window.addEventListener('resize', setCarouselHeight);

  cards.forEach((_, i) => {
    const d = document.createElement('button');
    d.className = 'carousel-dot' + (i === 0 ? ' active' : '');
    d.setAttribute('aria-label', 'Go to project ' + (i + 1));
    d.addEventListener('click', () => goTo(i));
    dotsContainer.appendChild(d);
  });

  function getClasses(index) {
    const total = cards.length;
    const prev = (current - 1 + total) % total;
    const next = (current + 1) % total;
    if (index === current) return 'active';
    if (index === prev) return 'prev-peek';
    if (index === next) return 'next-peek';
    return '';
  }

  function render() {
    const dots = dotsContainer.querySelectorAll('.carousel-dot');
    cards.forEach((card, i) => {
      card.className = 'project-card';
      const cls = getClasses(i);
      if (cls) card.classList.add(cls);
    });
    dots.forEach((d, i) => d.classList.toggle('active', i === current));
    currentNum.textContent = current + 1;
  }

  function goTo(index) {
    if (animating || index === current) return;
    animating = true;
    const dir = index > current ? 'exit-left' : 'exit-right';
    const enterFrom = index > current ? 'exit-right' : 'exit-left';

    cards[current].className = 'project-card ' + dir;
    cards[index].style.transition = 'none';
    cards[index].className = 'project-card ' + enterFrom;
    cards[index].offsetHeight;
    current = index;
    cards[index].style.transition = '';
    render();
    setTimeout(() => { animating = false; }, 650);
  }

  document.getElementById('prevBtn').addEventListener('click', () => {
    goTo((current - 1 + cards.length) % cards.length);
  });
  document.getElementById('nextBtn').addEventListener('click', () => {
    goTo((current + 1) % cards.length);
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'ArrowLeft') goTo((current - 1 + cards.length) % cards.length);
    if (e.key === 'ArrowRight') goTo((current + 1) % cards.length);
  });

  let touchStartX = 0;
  carouselEl.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
  carouselEl.addEventListener('touchend', e => {
    const dx = e.changedTouches[0].clientX - touchStartX;
    if (Math.abs(dx) > 50) dx < 0
      ? goTo((current + 1) % cards.length)
      : goTo((current - 1 + cards.length) % cards.length);
  });

  render();

</script>
</body>
</html>
