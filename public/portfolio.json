    </div>
  </div>
</section>

<!-- EXPERIENCE -->
<section id="experience">
  <div class="section-header reveal">
    <span class="section-number">01 /</span>
    <h2 class="section-title">Experience</h2>
    <div class="section-line"></div>
  </div>
  <div class="exp-card reveal">
    <div class="exp-role">Full Stack Web Development Intern</div>
    <div class="exp-company">Prinston Smart Engineers</div>
    <div class="exp-date">September 2024 – October 2024</div>
    <p class="exp-desc">
      Developed responsive web applications and an e-commerce application. Integrated frontend with 
