<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Vaishnavi B — Software Engineer</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Mono:wght@300;400;500&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0a0f;
    --surface: #111118;
    --card: #16161f;
    --border: #2a2a3a;
    --accent: #c8f05a;
    --accent2: #7b61ff;
    --accent3: #ff6b6b;
    --text: #e8e8f0;
    --muted: #7a7a9a;
    --heading: #ffffff;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Mono', monospace;
    font-size: 14px;
    line-height: 1.7;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9999;
    opacity: 0.4;
  }

  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(200,240,90,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(200,240,90,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
    z-index: 0;
  }

  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 1000;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.2rem 3rem;
    background: rgba(10,10,15,0.85);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
  }

  .nav-logo {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 1.1rem;
    color: var(--accent);
    letter-spacing: 0.05em;
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    list-style: none;
  }

  .nav-links a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--accent); }

  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 8rem 3rem 4rem;
    position: relative;
    overflow: hidden;
  }

  .hero-bg-circle {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.15;
    pointer-events: none;
  }

  .hero-bg-circle.c1 {
    width: 600px; height: 600px;
    background: var(--accent2);
    top: -200px; right: -100px;
    animation: float1 8s ease-in-out infinite;
  }

  .hero-bg-circle.c2 {
    width: 400px; height: 400px;
    background: var(--accent);
    bottom: -100px; left: 10%;
    animation: float2 10s ease-in-out infinite;
  }

  @keyframes float1 {
    0%, 100% { transform: translate(0,0) scale(1); }
    50% { transform: translate(30px, 40px) scale(1.05); }
  }
  @keyframes float2 {
    0%, 100% { transform: translate(0,0); }
    50% { transform: translate(-20px, -30px); }
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 900px;
  }

  .hero-label {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    opacity: 0;
    animation: fadeUp 0.6s ease forwards 0.2s;
  }

  .hero-label::before {
    content: '';
    width: 30px; height: 1px;
    background: var(--accent);
  }

  .hero-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(4rem, 9vw, 8rem);
    font-weight: 300;
    line-height: 0.95;
    color: var(--heading);
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
    opacity: 0;
    animation: fadeUp 0.8s ease forwards 0.4s;
  }

  .hero-name em {
    font-style: italic;
    color: var(--accent);
  }

  .hero-title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(0.8rem, 2vw, 1rem);
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 1.5rem;
    margin-bottom: 2rem;
    opacity: 0;
    animation: fadeUp 0.8s ease forwards 0.6s;
  }

  .hero-desc {
    max-width: 560px;
    color: var(--muted);
    font-size: 0.85rem;
    line-height: 1.8;
    opacity: 0;
    animation: fadeUp 0.8s ease forwards 0.8s;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    margin-top: 2.5rem;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeUp 0.8s ease forwards 1s;
  }

  .btn {
    padding: 0.75rem 1.75rem;
    border-radius: 2px;
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s;
    display: inline-block;
  }

  .btn-primary {
    background: var(--accent);
    color: #0a0a0f;
    border: 1px solid var(--accent);
    font-weight: 500;
  }

  .btn-primary:hover {
    background: transparent;
    color: var(--accent);
  }

  .btn-ghost {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border);
  }

  .btn-ghost:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .hero-contacts {
    display: flex;
    gap: 2rem;
    margin-top: 3.5rem;
    opacity: 0;
    animation: fadeUp 0.8s ease forwards 1.2s;
    flex-wrap: wrap;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--muted);
    font-size: 0.72rem;
    text-decoration: none;
    transition: color 0.2s;
  }

  .contact-item:hover { color: var(--accent); }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  section {
    padding: 6rem 3rem;
    position: relative;
    z-index: 1;
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 3.5rem;
  }

  .section-number {
    font-size: 0.65rem;
    color: var(--accent);
    letter-spacing: 0.15em;
    font-family: 'DM Mono', monospace;
  }

  .section-title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    color: var(--heading);
    letter-spacing: -0.02em;
  }

  .section-line {
    flex: 1;
    height: 1px;
    background: var(--border);
    max-width: 200px;
  }

  #experience { background: var(--surface); }

  .exp-card {
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 2rem 2.5rem;
    background: var(--card);
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s;
    max-width: 900px;
  }

  .exp-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: var(--accent);
  }

  .exp-card:hover { border-color: var(--accent); }

  .exp-role {
    font-family: 'Syne', sans-serif;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--heading);
    margin-bottom: 0.3rem;
  }

  .exp-company {
    color: var(--accent);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    margin-bottom: 0.3rem;
  }

  .exp-date {
    color: var(--muted);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .exp-desc {
    color: var(--muted);
    font-size: 0.82rem;
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    padding: 0.2rem 0.65rem;
    border: 1px solid var(--border);
    border-radius: 2px;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    color: var(--muted);
    transition: all 0.2s;
  }

  .tag:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* ── PROJECTS CAROUSEL ── */
  .projects-carousel-wrapper {
    position: relative;
  }

  .projects-carousel {
    position: relative;
    width: 100%;
    perspective: 1200px;
    /* height is set by JS to match the tallest card */
  }

  .project-card {
    position: absolute;
    top: 0; left: 0; right: 0;
    /* no bottom: 0 — height is natural, driven by content */
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 2.5rem 3rem;
    background: var(--card);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    backface-visibility: hidden;
    transform-origin: center center;
    transition: transform 0.6s cubic-bezier(0.77,0,0.175,1),
                opacity 0.6s ease,
                border-color 0.3s;
    opacity: 0;
    pointer-events: none;
    user-select: none;
  }

  .project-card.active {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(0) rotateY(0deg) scale(1);
    z-index: 3;
    border-color: var(--accent);
    box-shadow: 0 0 60px rgba(200,240,90,0.07), 0 30px 80px rgba(0,0,0,0.4);
  }

  .project-card.exit-left {
    opacity: 0;
    transform: translateX(-110%) rotateY(30deg) scale(0.88);
    z-index: 2;
  }

  .project-card.exit-right {
    opacity: 0;
    transform: translateX(110%) rotateY(-30deg) scale(0.88);
    z-index: 2;
  }

  .project-card.prev-peek {
    opacity: 0.18;
    transform: translateX(-88%) rotateY(20deg) scale(0.88);
    z-index: 1;
    pointer-events: none;
  }

  .project-card.next-peek {
    opacity: 0.18;
    transform: translateX(88%) rotateY(-20deg) scale(0.88);
    z-index: 1;
    pointer-events: none;
  }

  .project-card-top { display: flex; flex-direction: column; gap: 0.4rem; }

  .project-icon {
    font-size: 2.2rem;
    margin-bottom: 0.75rem;
    display: block;
  }

  .project-title {
    font-family: 'Syne', sans-serif;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--heading);
    margin-bottom: 0.15rem;
  }

  .project-date {
    font-size: 0.65rem;
    color: var(--accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .project-tagline {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    color: var(--accent);
    font-size: 1.05rem;
    margin-bottom: 1rem;
  }

  .project-desc {
    color: var(--muted);
    font-size: 0.82rem;
    line-height: 1.85;
    margin-bottom: 1.5rem;
    flex: 1;
  }

  /* Nav controls */
  .carousel-controls {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .carousel-btn {
    width: 44px; height: 44px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: var(--card);
    color: var(--text);
    font-size: 1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    flex-shrink: 0;
  }

  .carousel-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(200,240,90,0.06);
  }

  .carousel-dots {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .carousel-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--border);
    cursor: pointer;
    transition: all 0.3s;
    border: none;
    padding: 0;
  }

  .carousel-dot.active {
    background: var(--accent);
    width: 22px;
    border-radius: 3px;
  }

  .carousel-counter {
    margin-left: auto;
    font-size: 0.7rem;
    color: var(--muted);
    letter-spacing: 0.1em;
  }

  .carousel-counter span {
    color: var(--accent);
    font-family: 'Syne', sans-serif;
    font-weight: 700;
  }

  #skills { background: var(--surface); }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .skill-group {
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1.75rem;
    background: var(--card);
    transition: border-color 0.3s;
  }

  .skill-group:hover { border-color: var(--accent2); }

  .skill-group-title {
    font-family: 'Syne', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .skill-group-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .skill-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-pill {
    padding: 0.3rem 0.75rem;
    background: rgba(200,240,90,0.06);
    border: 1px solid rgba(200,240,90,0.15);
    border-radius: 2px;
    font-size: 0.7rem;
    color: var(--text);
    letter-spacing: 0.05em;
  }

  .edu-items {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 900px;
  }

  .edu-card {
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1.75rem 2rem;
    background: var(--card);
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    align-items: start;
    transition: border-color 0.3s;
  }

  .edu-card:hover { border-color: var(--accent2); }

  .edu-degree {
    font-family: 'Syne', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--heading);
    margin-bottom: 0.2rem;
  }

  .edu-school {
    color: var(--accent);
    font-size: 0.78rem;
    margin-bottom: 0.2rem;
  }

  .edu-field {
    color: var(--muted);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .edu-meta { text-align: right; }

  .edu-score {
    font-family: 'Syne', sans-serif;
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--accent);
  }

  .edu-score-label {
    font-size: 0.6rem;
    color: var(--muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .edu-year {
    font-size: 0.68rem;
    color: var(--muted);
    margin-top: 0.25rem;
  }

  #certifications { background: var(--surface); }

  .cert-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }

  .cert-card {
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1.25rem 1.5rem;
    background: var(--card);
    transition: all 0.3s;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .cert-card:hover {
    border-color: var(--accent3);
    transform: translateY(-2px);
  }

  .cert-name {
    font-family: 'Syne', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--heading);
    line-height: 1.4;
  }

  .cert-issuer {
    color: var(--accent3);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
  }

  .cert-date {
    color: var(--muted);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
  }

  footer {
    border-top: 1px solid var(--border);
    padding: 3rem;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .footer-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3rem;
    font-weight: 300;
    color: var(--heading);
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .footer-name em {
    font-style: italic;
    color: var(--accent);
  }

  .footer-links {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .footer-links a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .footer-links a:hover { color: var(--accent); }

  .footer-copy {
    color: var(--muted);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
  }

  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .reveal.visible {
    opacity: 1;
    transform: none;
  }

  .cursor-dot {
    position: fixed;
    width: 6px; height: 6px;
    background: var(--accent);
    border-radius: 50%;
    pointer-events: none;
    z-index: 99999;
    transform: translate(-50%, -50%);
    transition: left 0.05s, top 0.05s;
  }

  @media (max-width: 768px) {
    nav { padding: 1rem 1.5rem; }
    .nav-links { gap: 1.2rem; }
    .nav-links a { font-size: 0.65rem; }
    section { padding: 4rem 1.5rem; }
    .hero { padding: 6rem 1.5rem 3rem; }
    .edu-card { grid-template-columns: 1fr; }
    .edu-meta { text-align: left; }
    footer { padding: 2rem 1.5rem; }
  }
</style>
</head>
<body>

<div class="cursor-dot" id="cursorDot"></div>

<nav>
  <a href="#" class="nav-logo">VB</a>
  <ul class="nav-links">
    <li><a href="#experience">Experience</a></li>
    <li><a href="#projects">Projects</a></li>
    <li><a href="#skills">Skills</a></li>
    <li><a href="#education">Education</a></li>
    <li><a href="#certifications">Certs</a></li>
  </ul>
</nav>

<!-- HERO -->
